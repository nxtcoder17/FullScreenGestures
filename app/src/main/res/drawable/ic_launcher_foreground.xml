<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Phone Screen Bezel Outline -->
    <path
        android:pathData="M34,22 A6,6 0 0,1 40,16 H68 A6,6 0 0,1 74,22 V86 A6,6 0 0,1 68,92 H40 A6,6 0 0,1 34,86 Z"
        android:strokeColor="#22FFFFFF"
        android:strokeWidth="2"
        android:fillColor="#00000000" />

    <!-- Left Swipe Bulge (Bezier curve) -->
    <path
        android:pathData="M 34,42 C 34,42 43,48 43,54 C 43,60 34,66 34,66 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="34"
                android:startY="54"
                android:endX="43"
                android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#7FBB86FC" />
                <item android:offset="1.0" android:color="#FF6200EE" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right Swipe Bulge (Bezier curve) -->
    <path
        android:pathData="M 74,42 C 74,42 65,48 65,54 C 65,60 74,66 74,66 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="74"
                android:startY="54"
                android:endX="65"
                android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#7FBB86FC" />
                <item android:offset="1.0" android:color="#FF6200EE" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom Swipe Bulge (Bezier curve) -->
    <path
        android:pathData="M 46,92 C 46,92 52,83 58,83 C 64,83 70,92 70,92 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="58"
                android:startY="92"
                android:endX="58"
                android:endY="83"
                android:type="linear">
                <item android:offset="0.0" android:color="#7FBB86FC" />
                <item android:offset="1.0" android:color="#FF6200EE" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Left Gesture Arrow pointing right -->
    <path
        android:pathData="M40,54 L44,54 M42,52 L44,54 L42,56"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Right Gesture Arrow pointing left -->
    <path
        android:pathData="M68,54 L64,54 M66,52 L64,54 L66,56"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Bottom Gesture Arrow pointing up -->
    <path
        android:pathData="M58,86 L58,82 M56,84 L58,82 L60,84"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

</vector>